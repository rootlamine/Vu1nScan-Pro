generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ReportFormat {
  PDF
  JSON
}

enum ModuleStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}

enum ModuleCategory {
  SECURITY
  NETWORK
  OSINT
  SCRAPING
  WEB_OFFENSIVE
  API_OFFENSIVE
  NETWORK_OFFENSIVE
  SYSTEM
}

model User {
  id           String           @id @default(uuid())
  username     String           @unique
  email        String           @unique
  passwordHash String
  role         Role             @default(USER)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  scans        Scan[]
  profiles     ScanProfile[]
  permissions  UserPermissions?
}

model UserPermissions {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Limites quantitatives
  maxScansPerDay        Int      @default(10)
  maxScansPerMonth      Int      @default(100)
  maxConcurrentScans    Int      @default(2)
  maxTargetsPerScan     Int      @default(1)
  maxThreads            Int      @default(5)
  maxScanDuration       Int      @default(300)
  maxScanDepth          String   @default("normal")
  // Catégories & modules
  allowedCategories     String[]
  blockedModules        String[]
  // Feature flags
  canUseOffensiveModules Boolean @default(false)
  canGenerateReports    Boolean  @default(true)
  canExportData         Boolean  @default(true)
  canCreateProfiles     Boolean  @default(true)
  canScanInternalIPs    Boolean  @default(false)
  canUseDeepScan        Boolean  @default(false)
  canScheduleScans      Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Scan {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  targetUrl       String
  description     String?
  status          ScanStatus         @default(PENDING)
  depth           String             @default("normal")
  threads         Int                @default(5)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  vulnerabilities Vulnerability[]
  moduleResults   ScanModuleResult[]
  report          Report?
}

model Vulnerability {
  id              String    @id @default(uuid())
  scanId          String
  scan            Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  name            String
  severity        Severity
  cvssScore       Float?
  cvssVector      String?
  cveId           String?
  cweId           String?
  endpoint        String?
  parameter       String?
  description     String
  payload         String?
  evidence        String?
  impact          String?
  recommendation  String
  references      String[]
  isResolved      Boolean   @default(false)
  isFalsePositive Boolean   @default(false)
  notes           String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
}

model ScanModule {
  id             String             @id @default(uuid())
  name           String
  slug           String             @unique
  description    String
  isActive       Boolean            @default(true)
  defaultEnabled Boolean            @default(true)
  category       ModuleCategory     @default(SECURITY)
  results        ScanModuleResult[]
}

model ScanModuleResult {
  id            String       @id @default(uuid())
  scanId        String
  scan          Scan         @relation(fields: [scanId], references: [id], onDelete: Cascade)
  moduleId      String
  module        ScanModule   @relation(fields: [moduleId], references: [id])
  status        ModuleStatus @default(PENDING)
  executionTime Int?
  rawOutput     String?
  createdAt     DateTime     @default(now())

  @@unique([scanId, moduleId])
}

model Report {
  id          String       @id @default(uuid())
  scanId      String       @unique
  scan        Scan         @relation(fields: [scanId], references: [id], onDelete: Cascade)
  format      ReportFormat @default(PDF)
  filePath    String
  fileSize    Int?
  generatedAt DateTime     @default(now())
}

model ScanProfile {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  modules     String[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
}
